@{
    Layout = null;

    string recipe = ViewBag.recipe as string ?? "";

    if (!string.IsNullOrWhiteSpace(recipe))
    {
        recipe = recipe
            .Replace("###", "\n")
            .Replace("##", "\n")
            .Replace("**", "")
            .Replace("*", "•")
            .Replace("Yemek Adı:", "\nYemek Adı:")
            .Replace("Malzemeler:", "\nMalzemeler:")
            .Replace("Hazırlanışı:", "\nHazırlanışı:")
            .Replace("Pişirme Süresi:", "\nPişirme Süresi:")
            .Replace("Tavsiye:", "\nTavsiye:");
    }
}

<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yemek Tarifi Öner</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #f8f6f4, #efe7f7);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #3f3a4f;
        }

        .page-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 50px 15px;
        }

        .main-card {
            width: 100%;
            max-width: 820px;
            background: #ffffff;
            border-radius: 24px;
            padding: 35px;
            box-shadow: 0 15px 35px rgba(92, 84, 112, 0.18);
        }

        .header-area {
            text-align: center;
            margin-bottom: 30px;
        }

        .header-icon {
            width: 70px;
            height: 70px;
            background: #e8dff5;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px auto;
            font-size: 34px;
        }

        h2 {
            color: #5c5470;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .subtitle {
            color: #7b728d;
            font-size: 15px;
            margin-bottom: 0;
        }

        .form-box {
            background: #faf8fc;
            border: 1px solid #ece4f6;
            padding: 22px;
            border-radius: 18px;
            margin-bottom: 25px;
        }

        .form-label {
            font-weight: 700;
            color: #5c5470;
            margin-bottom: 10px;
        }

        .form-control {
            border-radius: 14px;
            padding: 13px 15px;
            border: 1px solid #d8c9ea;
            color: #4a425c;
        }

            .form-control:focus {
                border-color: #a084ca;
                box-shadow: 0 0 0 0.2rem rgba(160, 132, 202, 0.18);
            }

        .btn-primary {
            background: #a084ca;
            border: none;
            font-weight: 700;
            padding: 13px 18px;
            border-radius: 14px;
            transition: 0.2s ease;
        }

            .btn-primary:hover {
                background: #8466a1;
                transform: translateY(-1px);
            }

        .example-text {
            font-size: 13px;
            color: #8a819c;
            margin-top: 8px;
        }

        .result-box {
            background: #f3ecfb;
            border: 1px solid #dfd0f0;
            border-radius: 20px;
            padding: 25px;
            margin-top: 25px;
        }

        .result-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 18px;
            border-bottom: 1px solid #d6c5ea;
            padding-bottom: 12px;
        }

            .result-header h4 {
                margin: 0;
                color: #5c5470;
                font-weight: 800;
            }

        .recipe-content {
            background: #ffffff;
            border-radius: 16px;
            padding: 22px;
            color: #4a425c;
            font-size: 15.5px;
            line-height: 1.8;
            white-space: pre-line;
            word-break: break-word;
            border-left: 5px solid #a084ca;
        }

        .empty-box {
            margin-top: 20px;
            padding: 18px;
            background: #fff8e8;
            border-radius: 15px;
            color: #806226;
            font-size: 14px;
            text-align: center;
        }

        .footer-note {
            margin-top: 22px;
            text-align: center;
            color: #9a91aa;
            font-size: 13px;
        }

        @@media (max-width: 576px) {
            .main-card {
                padding: 25px 18px;
                border-radius: 18px;
            }

            .recipe-content {
                font-size: 14px;
                padding: 18px;
            }
        }
    </style>
</head>

<body>

    <div class="page-wrapper">
        <div class="main-card">

            <div class="header-area">
                <div class="header-icon">🍽</div>
                <h2>AI Tarif Önerici</h2>
                <p class="subtitle">
                    Elindeki malzemeleri gir, yapabileceğin pratik yemekleri öğren.
                </p>
            </div>

            <div class="form-box">
                <form method="post">
                    <label for="ingredients" class="form-label">
                        Malzemelerinizi Giriniz
                    </label>

                    <input type="text"
                           id="ingredients"
                           name="ingredients"
                           class="form-control"
                           placeholder="Örn: Domates, marul, ekmek, zeytinyağı, peynir"
                           required />

                    <div class="example-text">
                        Malzemeleri virgül ile ayırarak yazabilirsiniz.
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mt-4">
                        🥣 Tarif Öner
                    </button>
                </form>
            </div>

            @if (!string.IsNullOrWhiteSpace(recipe))
            {
                <div class="result-box">
                    <div class="result-header">
                        <span style="font-size: 28px;">🥘</span>
                        <h4>AI Önerisi</h4>
                    </div>

                    <div class="recipe-content">
                        @recipe
                    </div>
                </div>
            }
            else
            {
                <div class="empty-box">
                    Henüz bir tarif oluşturulmadı. Malzemelerinizi girerek tarif önerisi alabilirsiniz.
                </div>
            }

            <div class="footer-note">
                Tarifler AI tarafından önerilir. Damak zevkinize göre malzemeleri değiştirebilirsiniz.
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>